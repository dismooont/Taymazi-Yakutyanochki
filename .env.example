# Скопируйте в .env и заполните. Файл .env НЕ коммитить (см. .gitignore).

# Обязательно: токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF... (вставьте свой токен от @BotFather)

# Необязательно (значения по умолчанию заданы в Dockerfile/коде):
# INDEX_DIR=index
# USER_PHOTOS_DIR=data/user_photos
# TOP_K=5

# HTTP-прокси для доступа к api.telegram.org, если провайдер режет Telegram.
# На сервере с прямым интернетом — оставить пустым/удалить.
#
# ВАЖНО: адрес указывается с точки зрения того, кто ходит в сеть.
#   бот запущен на хосте (python -m bot.bot):  http://127.0.0.1:10809
#   бот запущен в Docker:                      http://host.docker.internal:10809
# Внутри контейнера 127.0.0.1 — это сам контейнер, а не ваш VPN-клиент на хосте,
# и бот через такой адрес до Telegram не достучится.
# TELEGRAM_PROXY=http://host.docker.internal:10809

# --- Веб-приложение (web/, см. docs/WEB_PLAN.md) ---
# Порт, на котором nginx отдаёт интерфейс (docker compose up -d web ui).
# WEB_PORT=8080
# TRUST_PROXY выставляется в docker-compose автоматически. Вручную включать только
# если перед приложением стоит обратный прокси, который сам проставляет X-Real-IP:
# иначе клиент подделает заголовок и обойдёт ограничение частоты входа.
# TRUST_PROXY=0
# Адрес, по которому фронтенд обращается к API. От него зависит флаг Secure у cookie:
# по https он включается автоматически, на localhost — нет (иначе браузер не сохранит cookie).
# PUBLIC_URL=http://localhost:5173
# DATA_DIR=data                  # где лежат базы пользователей и app.db
# REGISTRATION_OPEN=1            # 0 — закрыть регистрацию (учебный стенд после набора людей)
# TELEGRAM_AUTH_ENABLED=0        # вход через Telegram Login Widget (нужен HTTPS-домен)
# TELEGRAM_BOT_USERNAME=my_search_bot   # имя бота без @, нужно виджету входа
#
# Служебный токен: им Telegram-бот доказывает API, что он свой. Задайте длинную
# случайную строку и укажите её обоим сервисам. Пока не задан, ручек /api/bot нет.
# SERVICE_TOKEN=zamenite-na-dlinnuyu-sluchaynuyu-stroku
# API_URL=http://web:8000        # куда бот ходит за поиском (задан в docker-compose)
# DEMO_INDEX_DIR=index           # индекс COCO как общая база только для чтения
#
# ВАЖНО про групповые чаты: по умолчанию у бота включён режим приватности, и Telegram
# показывает ему только команды. Чтобы бот видел присылаемые в группу фотографии,
# у @BotFather выполните /setprivacy -> Disable.
# SESSION_TTL_DAYS=30
# MIN_PASSWORD_LENGTH=10
# Квоты на пользователя:
# MAX_DB_PER_USER=5
# MAX_PHOTOS_PER_DB=5000
# MAX_BYTES_PER_USER=3221225472  # 3 ГБ

# Поиск по подписям: к обычному поиску добавляется второй путь — по сгенерированным
# подписям снимков, и оценки двух путей складываются. По замеру на MS COCO это даёт
# +5,2 п.п. Recall@1 на подписях BLIP (подробности и оговорки — docs/CAPTION_SEARCH.md).
#
# Выключено по умолчанию: нужна вторая модель (~90 МБ весов, ставится из
# requirements-dev.txt), а смысл появляется только когда подписи уже сгенерированы.
# Пока размечено меньше половины базы, слияние не включается само.
# CAPTION_SEARCH_ENABLED=0
# CAPTION_MODEL=sentence-transformers/all-MiniLM-L6-v2
#
# Фоновая генерация подписей (BLIP). Отдельный флаг: подписи можно сгенерировать и
# заранее командой scripts/generate_captions.py, не запуская BLIP в вебе. Веса BLIP
# ~944 МБ; можно положить в models/blip, тогда сеть при старте не нужна.
# Разметка идёт только в простое и уступает любому запросу — см. docs/CAPTION_SEARCH.md.
# CAPTION_AUTO_ENABLED=0
# CAPTION_IDLE_SECONDS=30        # столько секунд без запросов, чтобы начать размечать
# CAPTION_FORCE_AFTER=600        # но не реже этого — иначе активный юзер лишит базу подписей
# CAPTION_THREADS=0              # 0 = не ограничивать; меньше = медленнее, но не мешает поиску
# CAPTION_BLIP_MODEL=Salesforce/blip-image-captioning-base

# Порог «показывать только похожее»: результат с косинусом ниже порога в выдачу не
# идёт (по фото зебры не всплывают дорожные знаки). Умолчания измерены на COCO;
# пороги РАЗНЫЕ, потому что у CLIP косинусы текст->фото и фото->фото на разных шкалах.
# 0 — показывать всё, как раньше. Строже -> меньше и точнее; мягче -> больше выдача.
# SEARCH_TEXT_MIN_SCORE=0.24
# SEARCH_IMAGE_MIN_SCORE=0.75

# Только для сборки образа за "закрытой" сетью (локальный HTTP-прокси).
# На сервере с прямым интернетом оставить пустыми/удалить.
# BUILD_HTTP_PROXY=http://host.docker.internal:10809
# BUILD_HTTPS_PROXY=http://host.docker.internal:10809
