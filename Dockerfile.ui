# Фронтенд: сборка Vite в статику, отдача через nginx.
# Второй ступенью берётся nginx, а не node, — на рантайме сборщик не нужен,
# и образ получается на порядок легче.

FROM node:22-alpine AS build
WORKDIR /ui

# package*.json копируются отдельно: слой с npm ci переиспользуется, пока
# зависимости не менялись, даже если исходники правились.
COPY web-ui/package.json web-ui/package-lock.json ./
RUN npm ci

COPY web-ui/ ./
RUN npm run build

FROM nginx:1.27-alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /ui/dist /usr/share/nginx/html

EXPOSE 80
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD wget -q --spider http://127.0.0.1/ || exit 1
