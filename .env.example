# Скопируйте в .env и заполните. Файл .env НЕ коммитить (см. .gitignore).

# Обязательно: токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF... (вставьте свой токен от @BotFather)

# Необязательно (значения по умолчанию заданы в Dockerfile/коде):
# INDEX_DIR=index
# USER_PHOTOS_DIR=data/user_photos
# TOP_K=5

# HTTP-прокси для доступа к api.telegram.org, если провайдер режет Telegram.
# Локально (Windows + VPN-клиент): http://127.0.0.1:10809
# На сервере с прямым интернетом — оставить пустым/удалить.
# TELEGRAM_PROXY=http://127.0.0.1:10809

# --- Веб-приложение (web/, см. docs/WEB_PLAN.md) ---
# Порт, на котором nginx отдаёт интерфейс (docker compose up -d web ui).
# WEB_PORT=8080
# TRUST_PROXY выставляется в docker-compose автоматически. Вручную включать только
# если перед приложением стоит обратный прокси, который сам проставляет X-Real-IP:
# иначе клиент подделает заголовок и обойдёт ограничение частоты входа.
# TRUST_PROXY=0
# Адрес, по которому фронтенд обращается к API. От него зависит флаг Secure у cookie:
# по https он включается автоматически, на localhost — нет (иначе браузер не сохранит cookie).
# PUBLIC_URL=http://localhost:5173
# DATA_DIR=data                  # где лежат базы пользователей и app.db
# REGISTRATION_OPEN=1            # 0 — закрыть регистрацию (учебный стенд после набора людей)
# TELEGRAM_AUTH_ENABLED=0        # вход через Telegram Login Widget (нужен HTTPS-домен)
# TELEGRAM_BOT_USERNAME=my_search_bot   # имя бота без @, нужно виджету входа
# TELEGRAM_BOT_ENABLED=1         # бот работает внутри веб-процесса; 0 — выключить
# DEMO_INDEX_DIR=index           # индекс COCO как общая база только для чтения
#
# ВАЖНО про групповые чаты: по умолчанию у бота включён режим приватности, и Telegram
# показывает ему только команды. Чтобы бот видел присылаемые в группу фотографии,
# у @BotFather выполните /setprivacy -> Disable.
# SESSION_TTL_DAYS=30
# MIN_PASSWORD_LENGTH=10
# Квоты на пользователя:
# MAX_DB_PER_USER=5
# MAX_PHOTOS_PER_DB=5000
# MAX_BYTES_PER_USER=3221225472  # 3 ГБ

# Только для сборки образа за "закрытой" сетью (локальный HTTP-прокси).
# На сервере с прямым интернетом оставить пустыми/удалить.
# BUILD_HTTP_PROXY=http://host.docker.internal:10809
# BUILD_HTTPS_PROXY=http://host.docker.internal:10809
